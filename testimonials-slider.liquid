{%- style -%}
  /* Desktop Styles */
  .testi-section-{{ section.id }} {
    width: 100%;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% else %}
      background-color: {{ section.settings.bg_color }};
    {% endif %}
  }

  .testi-container-{{ section.id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .testi-header-{{ section.id }} {
    text-align: {{ section.settings.text_align }};
    margin-bottom: 50px;
  }

  .testi-header-{{ section.id }} h2 {
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    margin-bottom: 15px;
    line-height: 1.2;
    font-weight: 600;
  }

  .testi-header-{{ section.id }} p {
    font-size: {{ section.settings.sub_text_size }}px;
    color: {{ section.settings.heading_color }};
    max-width: 700px;
    {% if section.settings.text_align == 'center' %} margin: 0 auto; {% endif %}
    opacity: 0.8;
  }

  /* Card Styling */
  .testi-card-{{ section.id }} {
    background-color: {{ section.settings.card_bg }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: 40px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all 0.3s ease;
    border: 1px solid rgba(0,0,0,0.05);
    box-shadow: 0 4px 15px rgba(0,0,0,0.02);
  }
  
  .testi-card-{{ section.id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
  }

  .testi-stars-{{ section.id }} {
    color: {{ section.settings.star_color }};
    font-size: 18px;
    margin-bottom: 20px;
    letter-spacing: 2px;
  }

  .testi-quote-{{ section.id }} {
    font-style: italic;
    font-size: 16px;
    color: {{ section.settings.card_text_color }};
    line-height: 1.7;
    margin-bottom: 30px;
  }

  .testi-footer-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 15px;
    border-top: 1px solid rgba(0,0,0,0.05);
    padding-top: 20px;
  }

  .testi-avatar-{{ section.id }} {
    width: 55px;
    height: 55px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid {{ section.settings.star_color }};
  }

  .testi-avatar-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testi-info-{{ section.id }} h4 { 
    font-size: 18px;
    margin: 0;
    color: {{ section.settings.heading_color }};
    font-weight: 600;
  }

  .testi-info-{{ section.id }} span {
    font-size: 13px;
    color: {{ section.settings.card_text_color }};
    opacity: 0.7;
    display: block;
  }

  /* Splide Dots Customization */
  .splide__pagination {
    bottom: -40px !important;
  }
  .splide__pagination__page {
    background: #ccc;
    height: 8px;
    width: 8px;
    transition: all 0.3s ease;
  }
  .splide__pagination__page.is-active {
    background: {{ section.settings.heading_color }};
    width: 24px;
    border-radius: 4px;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 768px) {
    .testi-section-{{ section.id }} { 
      padding-top: {{ section.settings.padding_top_mobile }}px; 
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px; 
    }
    .testi-header-{{ section.id }} h2 { font-size: 28px; }
    .testi-card-{{ section.id }} { padding: 25px; }
    .testi-header-{{ section.id }} { margin-bottom: 30px; }
  }
{%- endstyle -%}

<section class="testi-section-{{ section.id }}" aria-label="Testimonials">
  <div class="testi-container-{{ section.id }}">
    
    {% if section.settings.title != blank %}
      <div class="testi-header-{{ section.id }}">
        <h2>{{ section.settings.title }}</h2>
        {% if section.settings.sub_text != blank %}
          <p>{{ section.settings.sub_text }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div id="testimonial-slider-{{ section.id }}" class="splide">
      <div class="splide__track">
        <ul class="splide__list">
          {% for block in section.blocks %}
            <li class="splide__slide" {{ block.shopify_attributes }}>
              <div class="testi-card-{{ section.id }}">
                <div>
                  <div class="testi-stars-{{ section.id }}">
                    {% for i in (1..block.settings.rating) %}
                      ★
                    {% endfor %}
                  </div>
                  <div class="testi-quote-{{ section.id }}">
                    "{{ block.settings.quote | escape }}"
                  </div>
                </div>
                
                <div class="testi-footer-{{ section.id }}">
                  <div class="testi-avatar-{{ section.id }}">
                    {% if block.settings.avatar != blank %}
                      <img src="{{ block.settings.avatar | img_url: '120x120', crop: 'center' }}" alt="{{ block.settings.name }}" loading="lazy">
                    {% else %}
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %}
                  </div>
                  <div class="testi-info-{{ section.id }}">
                    <h4>{{ block.settings.name }}</h4>
                    <span>{{ block.settings.title }}</span>
                  </div>
                </div>
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const el = document.querySelector('#testimonial-slider-{{ section.id }}');
    if (el && typeof Splide !== 'undefined') {
      new Splide(el, {
        type   : 'loop',
        perPage: 3,
        perMove: 1,
        gap    : '30px',
        arrows : {{ section.settings.show_arrows }},
        pagination: {{ section.settings.show_dots }},
        autoplay: {{ section.settings.autoplay }},
        interval: {{ section.settings.autoplay_speed }},
        breakpoints: {
          1024: {
            perPage: 2,
            gap: '20px',
          },
          768: {
            perPage: 1,
            gap: '15px',
          }
        }
      }).mount();
    }
  });
</script>

{% schema %}
{
  "name": "Testimonial Slider",
  "settings": [
    {
      "type": "header",
      "content": "Desktop Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Container Width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "header",
      "content": "Mobile Layout"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Mobile Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Mobile Padding Bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdf8f1"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Header Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Header Text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Heading",
      "default": "What Our Clients Say"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading Font Size",
      "default": 40
    },
    {
      "type": "textarea",
      "id": "sub_text",
      "label": "Sub-text",
      "default": "Real stories from people who have transformed their lives"
    },
    {
      "type": "range",
      "id": "sub_text_size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Sub-text Font Size",
      "default": 18
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading & Name Color",
      "default": "#7a6341"
    },
    {
      "type": "header",
      "content": "Card Styling"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#7a6341"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star Rating & Avatar Border",
      "default": "#7a6341"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Card Corner Roundness",
      "default": 20
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "unit": "ms",
      "label": "Autoplay Speed",
      "default": 5000
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Navigation Arrows",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Pagination Dots",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review Quote",
          "default": "Hamptons Balance completely transformed my approach to wellness."
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Client Avatar"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Client Name",
          "default": "Sarah Chen"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Client Designation",
          "default": "Marketing Executive"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial Slider",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}